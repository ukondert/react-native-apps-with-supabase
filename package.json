{
  "name": "workout-app-platform",
  "private": true,
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "storybook": "npm run storybook --workspace @workout/shared-components",
    "build-storybook": "npm run build-storybook --workspace @workout/shared-components",
    "clean": "rimraf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@storybook/react-webpack5": "^10.3.6",
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.1",
    "storybook": "^10.3.6",
    "tsup": "^8.5.0",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  }
}